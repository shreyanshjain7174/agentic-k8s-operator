# Research Swarm Demo Configuration
# Copy this to .env and fill in your actual credentials

# OpenAI API key (required for LiteLLM proxy)
OPENAI_API_KEY=sk-proj-your-openai-key-here

# LiteLLM master key (for authentication, optional for local dev)
LITELLM_MASTER_KEY=sk-master-key

# MinIO credentials (override for any shared/non-local environment)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password

# Postgres credentials (override defaults for any shared/non-local environment)
POSTGRES_USER=spans
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=spans

# Agent configuration
AGENT_ROLE=researcher
AGENT_TONE=neutral_academic
LOG_LEVEL=INFO

# Docker image tags (optional, for custom builds)
AGENT_IMAGE_TAG=latest
ORCHESTRATOR_IMAGE_TAG=latest
