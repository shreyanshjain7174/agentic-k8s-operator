# =============================================================================
#  Agentic Operator — Cluster Test Harness Configuration
#
#  Copy this file:  cp config.env.example config.env
#  Then fill in any required values before running the harness.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Path to the kubeconfig for your target cluster.
# For kind:  export KUBECONFIG="$(kind get kubeconfig --name agentic-k8s-dev)"
# For DOKS:  doctl kubernetes cluster kubeconfig save <cluster-name>
# For EKS:   aws eks update-kubeconfig --name <cluster-name>
KUBECONFIG="${KUBECONFIG:-$HOME/.kube/config}"

# ── Optional: LLM Provider (needed for E2E tests) ────────────────────────────

# Cloudflare Workers AI (cheapest option for E2E)
# CF_ACCOUNT_ID=""
# CF_API_TOKEN=""

# Or any OpenAI-compatible endpoint
# LLM_ENDPOINT=""
# LLM_API_KEY=""
# LLM_MODEL=""

# ── Optional: Operator Image ─────────────────────────────────────────────────

# Override the operator image used during Helm install.
# Defaults to the chart's appVersion.
# OPERATOR_IMAGE=""
# OPERATOR_IMAGE_TAG=""

# ── Optional: Agent Image ────────────────────────────────────────────────────

# Override the agent container image.
# AGENT_IMAGE=""

# ── Optional: Timeouts ───────────────────────────────────────────────────────

# Per-workload timeout in seconds (default: 300)
# WORKLOAD_TIMEOUT=300

# Helm install timeout (default: 180s)
# HELM_TIMEOUT="180s"

# ── Optional: Namespaces ─────────────────────────────────────────────────────

# Override default namespace names
# NS_ARGO="argo-workflows"
# NS_OPERATOR="agentic-system"
# NS_SHARED="shared-services"

# ── Optional: Cleanup ────────────────────────────────────────────────────────

# Set to "false" to keep test resources after run (for debugging)
# CLEANUP="true"

# ── Optional: Evidence ───────────────────────────────────────────────────────

# Directory for evidence collection (default: tests/harness/evidence/<timestamp>)
# EVIDENCE_DIR=""
